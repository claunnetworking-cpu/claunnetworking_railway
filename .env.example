# ClaunNetworking v5.3.0 — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores antes de subir o projeto.
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SuaSenhaSeguraAqui
POSTGRES_DB=claunnetworking

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# JWT_SECRET: mínimo 32 caracteres. Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-uma-chave-secreta-com-pelo-menos-32-chars
LOG_LEVEL=info
# CORS_ORIGIN: URL do frontend (sem barra final)
CORS_ORIGIN=http://localhost:5173

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL da API que o browser vai acessar
VITE_API_URL=http://localhost:3000
# UUID do tenant padrão (criado pela migration 002_seed_demo.sql)
VITE_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
